    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "@vitejs/plugin-react": "3.1.0",
    "autoprefixer": "10.5.4",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "eslint": "9.39.5",
    "eslint-plugin-react": "7.37.5",
